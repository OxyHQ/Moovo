{
  "name": "moovo-monorepo",
  "version": "1.0.0",
  "description": "Moovo — buy/sell marketplace by Oxy",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:frontend": "bun run --filter @moovo/frontend dev -- --clear --tunnel",
    "dev:backend": "bun run --filter @moovo/backend dev",
    "build": "bun run build:shared-types && bun run build:backend && bun run build:frontend",
    "build:shared-types": "bun run --filter @moovo/shared-types build",
    "build:frontend": "bun run --filter @moovo/frontend build",
    "build:backend": "bun run build:shared-types && bun run --filter @moovo/backend build",
    "start:frontend": "bun run --filter @moovo/frontend start",
    "start:backend": "bun run --filter @moovo/backend start",
    "lint": "bun run --filter '*' lint",
    "android": "bun run --filter @moovo/frontend android",
    "ios": "bun run --filter @moovo/frontend ios",
    "web": "bun run --filter @moovo/frontend web",
    "postinstall": "bun run --filter @moovo/shared-types build"
  },
  "keywords": [
    "monorepo",
    "marketplace",
    "expo",
    "api",
    "ecommerce"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.8.3",
    "react-native-reanimated": "4.3.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo-secure-store": "56.0.4",
    "expo-file-system": "56.0.8",
    "react-native-screens": "4.25.2",
    "react-native-gesture-handler": "2.31.1",
    "react-native-keyboard-controller": "1.20.7",
    "expo": "56.0.11",
    "expo-blur": "56.0.3",
    "expo-constants": "56.0.18",
    "expo-font": "56.0.6",
    "expo-image": "56.0.11",
    "@react-native-menu/menu": "2.0.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/metro-babel-transformer": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@oxyhq/core": "3.6.0",
    "lightningcss": "1.30.1",
    "lightningcss-linux-x64-gnu": "1.30.1",
    "lightningcss-linux-x64-musl": "1.30.1"
  },
  "dependencies": {
    "@oxyhq/auth": "^4.1.1",
    "@oxyhq/core": "3.6.0"
  }
}
