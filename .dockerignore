# BuildKit does NOT match nested directories with a bare `node_modules`/`dist`
# pattern — it would leak host node_modules / stale build output into the build
# context. Use `**/` so every workspace's copy is excluded (Bun-1.3 gotcha).
**/node_modules
**/dist
**/.expo
**/coverage
.env
.env.*
*.log
.git
.github
.vscode
.idea
.claude
docs
**/*.test.ts
**/__tests__
sst.config.ts
.do
