# Caching headers for Cloudflare Pages
# Note: When _worker.js (Advanced Mode) is active, these headers are set by the
# worker. This file serves as documentation and fallback if the worker is removed.

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable
