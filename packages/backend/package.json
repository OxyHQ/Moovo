{
  "name": "@moovo/backend",
  "version": "1.0.0",
  "description": "Moovo API — buy/sell marketplace backend by Oxy",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@moovo/shared-types": "workspace:*",
    "@oxyhq/core": "^12.2.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "esbuild": "^0.27.2",
    "expo-server-sdk": "^6.0.0",
    "express": "^4.21.2",
    "ioredis": "^5.10.0",
    "mongoose": "^9.1.3",
    "pino": "^10.3.1",
    "rate-limit-redis": "^5",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.15.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.0.8",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
