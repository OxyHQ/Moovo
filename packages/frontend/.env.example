# ================================
# EXPO APP CONFIGURATION
# ================================
# Moovo API base URL.
EXPO_PUBLIC_API_URL=http://localhost:3001

# Oxy API base URL (used by the Oxy SDK / OxyProvider).
EXPO_PUBLIC_OXY_API_URL=https://api.oxy.so

# Oxy SSO client id (registered RP client for cross-app device sign-in / SSO).
# Leave EMPTY until the Oxy client is registered — the SDK SSO/cold-boot flow
# activates once this is set. See HANDOFF.md.
EXPO_PUBLIC_OXY_CLIENT_ID=

# ================================
# NOTES
# ================================
# - Copy this file to .env and fill in your values.
# - The EXPO_PUBLIC_ prefix exposes vars to the client bundle — never put
#   secrets in EXPO_PUBLIC_ variables.
