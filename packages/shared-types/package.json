{
  "name": "@moovo/shared-types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for the Moovo frontend and backend",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "echo \"No lint configured for shared-types\" && exit 0",
    "test": "echo \"No tests specified\" && exit 0",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "typescript",
    "types",
    "shared",
    "marketplace"
  ],
  "author": "Oxy",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^25.0.8"
  },
  "files": [
    "dist/**/*"
  ]
}
